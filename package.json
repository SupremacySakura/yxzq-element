{
  "name": "@yxzq-element/workspace",
  "version": "1.1.0",
  "description": "Framework-agnostic Web Components built with Lit",
  "private": true,
  "type": "module",
  "author": "SupremacySakura",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SupremacySakura/yxzq-element.git"
  },
  "homepage": "https://supremacysakura.github.io/yxzq-element/",
  "bugs": {
    "url": "https://github.com/SupremacySakura/yxzq-element/issues"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm run build:library && pnpm --filter @yxzq-element/play dev",
    "dev:react": "pnpm run build:library && pnpm --filter @yxzq-element/example-react dev",
    "dev:vue": "pnpm run build:library && pnpm --filter @yxzq-element/example-vue dev",
    "build": "pnpm run build:library && pnpm run build:examples",
    "build:library": "pnpm --filter yxzq-element... --if-present build",
    "build:examples": "pnpm --filter @yxzq-element/play build && pnpm --filter \"./examples/*\" --if-present build",
    "typecheck": "tsc -p tsconfig.json && pnpm --filter \"./examples/*\" --if-present typecheck",
    "docs:dev": "pnpm run build:library && pnpm --filter @yxzq-element/docs dev",
    "docs:build": "pnpm run build:library && pnpm --filter @yxzq-element/docs build",
    "test": "vitest run",
    "release:version": "node ./scripts/set-release-version.mjs",
    "release:check": "pnpm typecheck && pnpm test && pnpm build && pnpm docs:build",
    "release:pack": "node ./scripts/pack-release.mjs",
    "release:prepare": "pnpm release:check && pnpm release:pack",
    "release:publish": "node ./scripts/publish-release.mjs"
  },
  "keywords": [
    "web-components",
    "lit"
  ],
  "license": "ISC",
  "devDependencies": {
    "@types/node": "20.11.20",
    "jsdom": "24.0.0",
    "postcss-color-mix": "1.1.0",
    "postcss-each": "1.1.0",
    "postcss-each-variables": "0.3.0",
    "postcss-for": "2.1.1",
    "postcss-nested": "6.0.1",
    "typescript": "5.2.2",
    "vite": "5.1.4",
    "vitest": "1.4.0"
  }
}
