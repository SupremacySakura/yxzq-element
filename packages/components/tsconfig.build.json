{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "paths": {},
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "index.ts",
    "Button/**/*.ts",
    "Checkbox/**/*.ts",
    "Input/**/*.ts",
    "Radio/**/*.ts",
    "Select/**/*.ts",
    "Switch/**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "dist"
  ]
}
