{
  "name": "@yxzq-element/components",
  "version": "1.0.1",
  "description": "Lit components for yxzq-element",
  "type": "module",
  "author": "SupremacySakura",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SupremacySakura/yxzq-element.git",
    "directory": "packages/components"
  },
  "homepage": "https://supremacysakura.github.io/yxzq-element/",
  "bugs": {
    "url": "https://github.com/SupremacySakura/yxzq-element/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/Button/index.d.ts",
      "import": "./dist/Button/index.js"
    },
    "./checkbox": {
      "types": "./dist/Checkbox/index.d.ts",
      "import": "./dist/Checkbox/index.js"
    },
    "./input": {
      "types": "./dist/Input/index.d.ts",
      "import": "./dist/Input/index.js"
    },
    "./radio": {
      "types": "./dist/Radio/index.d.ts",
      "import": "./dist/Radio/index.js"
    },
    "./select": {
      "types": "./dist/Select/index.d.ts",
      "import": "./dist/Select/index.js"
    },
    "./switch": {
      "types": "./dist/Switch/index.d.ts",
      "import": "./dist/Switch/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepack": "node ../../scripts/prepack-package.mjs @yxzq-element/components"
  },
  "license": "ISC",
  "dependencies": {
    "@yxzq-element/utils": "workspace:*",
    "lit": "^3.3.1"
  }
}
