{
  "name": "yxzq-element",
  "version": "1.0.1",
  "description": "Framework-agnostic Web Components built with Lit",
  "type": "module",
  "author": "SupremacySakura",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SupremacySakura/yxzq-element.git",
    "directory": "packages/core"
  },
  "homepage": "https://supremacysakura.github.io/yxzq-element/",
  "bugs": {
    "url": "https://github.com/SupremacySakura/yxzq-element/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "import": "./dist/button.js"
    },
    "./checkbox": {
      "types": "./dist/checkbox.d.ts",
      "import": "./dist/checkbox.js"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.js"
    },
    "./radio": {
      "types": "./dist/radio.d.ts",
      "import": "./dist/radio.js"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "import": "./dist/select.js"
    },
    "./switch": {
      "types": "./dist/switch.d.ts",
      "import": "./dist/switch.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": [
    "./dist/index.js",
    "./dist/button.js",
    "./dist/checkbox.js",
    "./dist/input.js",
    "./dist/radio.js",
    "./dist/select.js",
    "./dist/switch.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepack": "node ../../scripts/prepack-package.mjs yxzq-element"
  },
  "keywords": [
    "web-components",
    "lit"
  ],
  "license": "ISC",
  "dependencies": {
    "@yxzq-element/components": "workspace:*"
  }
}
